# ── Database (Turso SQLite) ──────────────────────────────────
TURSO_DATABASE_URL=       # Turso DB URL (libsql://...turso.io) or file:local.db for dev
TURSO_AUTH_TOKEN=         # Turso auth token (get from turso CLI or dashboard)

# ── AI Engine ────────────────────────────────────────────────
KIMI_API_KEY=             # Kimi API key (sk-...)

# ── WhatsApp (Kirimi.id) ─────────────────────────────────────
KIRIMI_USER_CODE=         # Kirimi user code
KIRIMI_SECRET=            # Kirimi secret
KIRIMI_DEVICE_ID=         # Default Kirimi device ID

# ── Payment (Flip) ───────────────────────────────────────────
FLIP_SECRET_KEY=          # Flip Basic Auth key

# ── App ──────────────────────────────────────────────────────
APP_URL=                  # https://umkm-ai.web.id (production)
NODE_ENV=                 # development | production

# ── OAuth (optional fallback) ────────────────────────────────
APP_SECRET=               # JWT signing secret
OWNER_UNION_ID=           # Admin union ID
